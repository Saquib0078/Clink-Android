<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_90sdp"
    android:gravity="center_vertical"
    android:orientation="vertical">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_45sdp"
                android:layout_centerVertical="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/frame10_gradieant">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginLeft="@dimen/_50sdp"
                            android:gravity="center_horizontal"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvf12"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello World"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="@dimen/_100sdp"
                                android:layout_height="@dimen/_1sdp"
                                android:layout_marginHorizontal="5dp"
                                android:background="@color/black" />

                            <TextView
                                android:id="@+id/tvf121"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello World"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_2sdp"
                            android:layout_alignParentBottom="true"
                            android:background="@color/f10bl" />
                    </RelativeLayout>

                </LinearLayout>
            </LinearLayout>

            <ImageView
                android:layout_width="@dimen/_45sdp"
                android:layout_height="@dimen/_45sdp"
                android:layout_marginLeft="@dimen/_5sdp"
                android:src="@drawable/congress" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="50dp"
             android:layout_height="@dimen/_90sdp"
            android:layout_alignParentRight="true"
            android:layout_marginRight="@dimen/_15sdp"
            android:orientation="horizontal"
         >

            <LinearLayout
                android:layout_width="@dimen/_8sdp"
                android:layout_height="@dimen/_90sdp"
                android:background="@color/darkorange" />

            <LinearLayout
                android:layout_width="@dimen/_8sdp"
                android:layout_height="@dimen/_90sdp"
                android:background="@color/flagM" />

            <LinearLayout
                android:layout_width="@dimen/_8sdp"
                android:layout_height="@dimen/_90sdp"
                android:background="@color/flagL" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivf12"
            android:layout_width="@dimen/_70sdp"
            android:layout_height="@dimen/_70sdp"
            android:background="@color/darkorange"
            android:layout_centerVertical="true"
            android:layout_marginRight="@dimen/_5sdp"
            android:layout_marginLeft="@dimen/_5sdp"
            app:strokeColor="@color/white"
            android:layout_alignParentRight="true"
            app:strokeWidth="@dimen/_2sdp"
            app:shapeAppearanceOverlay="@style/DecagonView"
            android:scaleType="centerCrop" />
    </RelativeLayout>


</LinearLayout>