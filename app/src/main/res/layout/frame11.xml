<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            >



            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/_35sdp"
                 >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/frame10_gradieant">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                             android:layout_toEndOf="@+id/ivbjp"
                            android:layout_marginLeft="@dimen/_5sdp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvf11"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello World"
                                android:textColor="@color/black"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="@dimen/_1sdp"
                                android:layout_height="20dp"
                                android:layout_marginHorizontal="5dp"
                                android:background="@color/black" />

                            <TextView
                                android:id="@+id/tvf111"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hello World"
                                android:textColor="@color/black"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivbjp"
                            android:layout_width="@dimen/_35sdp"
                            android:layout_height="@dimen/_35sdp"
                            android:layout_alignParentLeft="true"
                            android:adjustViewBounds="true"


                            android:layout_centerVertical="true"
                            android:layout_marginStart="@dimen/_2sdp"
                            android:layout_marginLeft="@dimen/_2sdp"
                            android:layout_marginTop="@dimen/_2sdp"
                            android:layout_marginEnd="@dimen/_2sdp"
                            android:layout_marginBottom="@dimen/_2sdp"
                            android:src="@drawable/shivsenaa" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/_2sdp"
                            android:background="@color/f10bl"
                            android:layout_alignParentBottom="true"/>
                    </RelativeLayout>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/lin1"
            android:layout_alignParentRight="true"
            android:layout_marginRight="@dimen/_5sdp"
            android:orientation="horizontal">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/_4sdp"
                android:layout_height="@dimen/_85sdp"
                android:backgroundTint="@color/darkorange"
                app:strokeWidth="0dp"/>
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/_4sdp"
                android:layout_height="@dimen/_85sdp"
                android:layout_marginLeft="@dimen/_3sdp"
                android:backgroundTint="@color/darkorange"
                app:strokeWidth="0dp"/>


            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivf11"
                android:layout_width="@dimen/_70sdp"
                android:layout_height="@dimen/_70sdp"
                android:background="@color/darkorange"
                android:layout_centerVertical="true"
                android:layout_marginRight="@dimen/_5sdp"
                android:layout_marginLeft="@dimen/_5sdp"
                app:strokeColor="@color/white"
                app:strokeWidth="@dimen/_2sdp"
                app:shapeAppearanceOverlay="@style/DecagonView"
                android:scaleType="centerCrop" />
            <LinearLayout
                android:id="@+id/lin2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@+id/ivf10"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/_4sdp"
                    android:layout_height="@dimen/_85sdp"
                    android:backgroundTint="@color/darkorange"
                    app:strokeWidth="0dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="@dimen/_4sdp"
                    android:layout_height="@dimen/_85sdp"
                    android:layout_marginLeft="@dimen/_3sdp"
                    android:backgroundTint="@color/darkorange"
                    app:strokeWidth="0dp" />

            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>

</LinearLayout>